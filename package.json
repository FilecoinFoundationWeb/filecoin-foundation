{
  "name": "filecoin-foundation",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "packageManager": "npm@10.9.3",
  "engines": {
    "npm": ">=10.9.0",
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint:md": "markdownlint-cli2 \"apps/**/*.md\" \"!**/node_modules/**\" --config .markdownlint.jsonc",
    "check:versions": "syncpack lint",
    "fix:versions": "syncpack fix",
    "prepare": "test \"$CI\" = \"true\" || husky",
    "changeset": "changeset add",
    "version": "changeset version",
    "publish": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "syncpack": "^14.3.1",
    "turbo": "^2.9.8"
  },
  "overrides": {
    "dompurify": "^3.3.0",
    "jsonpath-plus": "^10.3.0"
  },
  "version": "0.0.1",
  "dependencies": {
    "@percy/cli": "^1.31.13",
    "@sentry/nextjs": "^10.51.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@unlighthouse/cli": "^0.17.9",
    "@unlighthouse/core": "^0.17.7",
    "@vercel/speed-insights": "^2.0.0",
    "cypress": "^15.14.2",
    "globals": "^17.6.0",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "postcss": "^8.5.8",
    "puppeteer": "^24.42.0",
    "react-hook-form": "^7.75.0",
    "react-lite-youtube-embed": "^3.5.1",
    "slugify": "^1.6.8",
    "swr": "^2.4.1",
    "tailwindcss": "^4.2.2",
    "viem": "^2.48.8",
    "wagmi": "^3.6.9"
  }
}
